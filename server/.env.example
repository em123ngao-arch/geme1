# Đổi tên file này thành .env khi chạy ở máy tính (Local)
# Trên Render, hãy copy các biến này vào phần Environment Variables.

# Mật khẩu để mã hóa Token đăng nhập (Nên điền 1 chuỗi dài bất kỳ)
JWT_SECRET=super-secret-key-production-12345

# Đường link của trang web Vercel (Để Backend cho phép kết nối)
FRONTEND_URL=https://your-frontend-app.vercel.app

# API Key của Google Gemini (Phải có để AI hoạt động)
GEMINI_API_KEY=AIzaSy...

# Chuỗi kết nối Supabase PostgreSQL (Lấy từ Project Settings > Database > Connection string > URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxx.supabase.co:5432/postgres
